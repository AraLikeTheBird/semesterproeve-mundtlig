iv>\r\n                    <div class=\"option\">Wide</div>\r\n                </div>\r\n\r\n                <!-- proportions-->\r\n               <!-- <div class=\"options hidden\" data-group=\"proportion\" data-category=\"arms\">\r\n                    <label>Width</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"width\">\r\n\r\n                    <label>Height</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"height\">\r\n                </div> -->\r\n                <div class=\"options hidden\" data-group=\"proportion\" data-category=\"head\">\r\n                    <label>Width</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"width\">\r\n\r\n                    <label>Height</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"height\">\r\n                </div>\r\n                <div class=\"options hidden\" data-group=\"proportion\" data-category=\"body\">\r\n                    <label>Width</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"width\">\r\n\r\n                    <label>Height</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"height\">\r\n                </div>\r\n               <!-- <div class=\"options hidden\" data-group=\"proportion\" data-category=\"legs\">\r\n                    <label>Width</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"width\">\r\n\r\n                    <label>Height</label>\r\n                    <input type=\"range\" min=\"0.5\" max=\"1.5\" step=\"0.1\" value=\"1\" data-prop=\"height\">\r\n                </div> -->\r\n\r\n                <!-- PROPORTION OPTIONS -->\r\n     