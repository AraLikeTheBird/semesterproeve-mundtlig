en\" data-group=\"shape\" data-category=\"body\">\r\n                    <div class=\"option\" data-value=\"round\">Round</div>\r\n                    <div class=\"option\" data-value=\"tall-Rectangle\">Tall Rectangle</div>\r\n                    <div class=\"option\" data-value=\"square\">Square</div>\r\n                    <div class=\"option\" data-value=\"upwards-Triangle\">Upwards Triangle</div>\r\n                    <div class=\"option\" data-value=\"reverse-Triangle\">Reverse Diamond</div>\r\n                </div>\r\n\r\n                <!-- SILHOUETTE OPTIONS -->\r\n                <div class=\"options hidden\" data-group=\"silhouette\" data-category=\"physicaltraits\">\r\n                    <div class=\"option\" data-value=\"pointed-ears\">Pointed ears</div>\r\n                    <div class=\"option\" data-value=\"human-ears\">Human ears</div>\r\n                    <div class=\"option\" data-value=\"canine/cat-ears\">canine/cat ears</div>\r\n                    <div class=\"option\" data-value=\"grazer-ears\">grazer ears</div>\r\n                    <div class=\"option\" data-value=\"bob-hair\">Bob hair</div>\r\n                    <div class=\"option\" data-value=\"slick-back\">slick back</div>\r\n                    <div class=\"option\" data-value=\"half-updo\">half updo</div>\r\n                    <div class=\"option\" data-value=\"intricate-design\">intricate design</div>\r\n                    <div class=\"option\" data-value=\"messy-bun\">messy bun</div>\r\n                    <div class=\"option\" data-value=\"long-loose-hair\">long hair</div>\r\n\r\n                </div>\r\n                <div class=\"options hidden\" data-group=\"silhouette\" data-category=\"clothes\">\r\n                    <div class=\"option\" data-value=\"wide-pants\">wide pants <img src=\"assets/button%20covers/round%20head%20cover.png\" width=\"45px\"></div>\r\n                    <div class=\"option\" data-value=\"baggy-pants\">Baggy pants</div>\r\n                 